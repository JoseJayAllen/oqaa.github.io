# ============================================
# DocuManage Environment Configuration
# ============================================
# Copy this file to .env and update the values

# Flask Environment
FLASK_ENV=development
FLASK_APP=run.py
SECRET_KEY=your-super-secret-key-change-this-in-production

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production

# Database Configuration (MySQL)
# Format: mysql+pymysql://username:password@host:port/database
DATABASE_URL=mysql+pymysql://documanage_user:documanage_pass@localhost:3306/documanage_db

# For Development (SQLite - optional)
DEV_DATABASE_URL=sqlite:///documanage_dev.db

# File Upload Configuration
MAX_CONTENT_LENGTH=104857600
UPLOAD_FOLDER=uploads

# Email Configuration (Optional - for notifications)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@documanage.com

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Rate Limiting
RATELIMIT_STORAGE_URL=memory://

# Logging
LOG_LEVEL=INFO
